# ──────────────────────────────────────────────────────────────────────────
# Finders × Keepers — environment
# Copy this file to `.env.local` and fill in your Supabase project values.
# ──────────────────────────────────────────────────────────────────────────

# Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Bypasses RLS — used for seeding + team lifecycle actions.
# NEVER expose this to the browser or commit it.
SUPABASE_SERVICE_ROLE_KEY=

# Escrow provider seam: "stub" (default, in-memory) or "stripe" (real, test mode).
# "stripe" requires the STRIPE_* keys below + a webhook listener (see docs/stripe-setup.md).
ESCROW_PROVIDER=stub

# Stripe (TEST MODE) — required only when ESCROW_PROVIDER=stripe; ignored for the stub.
# Test keys: https://dashboard.stripe.com → toggle Test mode → Developers → API keys.
# Webhook secret: run `stripe listen --forward-to localhost:3000/api/stripe/webhook`.
# These are test-mode values (no real money); never commit real keys.
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...   # only when client-side payment UI lands

# App base URL for Stripe redirect targets (success/cancel). Dev default below.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Set to "true" only after adding Apple as an OAuth provider in Supabase Auth.
# Until then the "Continue with Apple" button stays hidden (email auth still works).
# NEXT_PUBLIC_APPLE_AUTH_ENABLED=true
