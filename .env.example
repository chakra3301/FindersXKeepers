# ──────────────────────────────────────────────────────────────────────────
# Finders × Keepers — environment
# Copy this file to `.env.local` and fill in your Supabase project values.
# ──────────────────────────────────────────────────────────────────────────

# Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Bypasses RLS — used for seeding + team lifecycle actions.
# NEVER expose this to the browser or commit it.
SUPABASE_SERVICE_ROLE_KEY=

# Escrow provider seam: "stub" (default, in-memory) or "stripe" (real, test mode).
# "stripe" requires the STRIPE_* keys below + a webhook listener (see docs/stripe-setup.md).
ESCROW_PROVIDER=stub

# Stripe (TEST MODE) — required only when ESCROW_PROVIDER=stripe; ignored for the stub.
# Test keys: https://dashboard.stripe.com → toggle Test mode → Developers → API keys.
# Webhook secret: run `stripe listen --forward-to localhost:3000/api/stripe/webhook`.
# These are test-mode values (no real money); never commit real keys.
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...   # only when client-side payment UI lands

# App base URL for Stripe redirect targets (success/cancel). Dev default below.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Login is passwordless: email one-time-code (OTP) for everyone, plus optional
# social sign-in. The form detects new vs returning emails and shows the right
# screen. For 6-digit CODES (not magic links), set the Supabase Auth email
# templates ("Magic Link" / "Confirm signup") to include {{ .Token }}.
#
# Each social button renders only after its provider is configured in Supabase
# Auth — flip the matching flag below once it's wired up (email OTP always works).
# NEXT_PUBLIC_APPLE_AUTH_ENABLED=true
# NEXT_PUBLIC_GOOGLE_AUTH_ENABLED=true

# Estimator seam: "stub" (default, deterministic — no key needed) or "deepseek".
# Sizes the pre-sourcing SHIPPING estimate and the item-value used for the escrow
# hold. "deepseek" routes those estimates through a DeepSeek model; any failure
# falls back to the deterministic stub so checkout is never blocked. The four
# pricing lines stay separate either way — the model only feeds inputs.
ESTIMATOR_PROVIDER=stub
# DeepSeek (OpenAI-compatible) — required only when ESTIMATOR_PROVIDER=deepseek.
# Key: https://platform.deepseek.com → API keys. Never commit a real key.
# DEEPSEEK_API_KEY=sk-...
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1   # default
# DEEPSEEK_MODEL=deepseek-chat                    # default

# Email seam: "stub" (default, logs to console — no key needed) or "resend".
# "resend" requires an API key + a verified From address.
EMAIL_PROVIDER=stub
# RESEND_API_KEY=re_...
# EMAIL_FROM=Finders Keepers <hello@yourdomain.com>   # must be a verified Resend sender
