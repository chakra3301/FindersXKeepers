# ──────────────────────────────────────────────────────────────────────────
# Finders × Keepers — environment
# Copy this file to `.env.local` and fill in your Supabase project values.
# ──────────────────────────────────────────────────────────────────────────

# Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Bypasses RLS — used for seeding + team lifecycle actions.
# NEVER expose this to the browser or commit it.
SUPABASE_SERVICE_ROLE_KEY=

# Escrow provider seam: "stub" now, "stripe" when Stripe Connect lands.
ESCROW_PROVIDER=stub
